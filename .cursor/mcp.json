{
  "mcpServers": {
    "cursorTools": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/cursorToolsMcp.py"
      ]
    },
    "workspaceTesting": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/workspaceTestingMcp.py"
      ]
    },
    "tddTestRunner": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/tddTestRunner.py"
      ]
    },
    "devDocs": {
      "command": "uvx",
      "args": [
        "--with",
        "httpx",
        "--with",
        "beautifulsoup4",
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/devDocsMcp.py"
      ]
    },
    "memory": {
      "command": "uvx",
      "env": {
        "WORKSPACE_ROOT": "${workspaceFolder}"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/memoryMcp.py"
      ]
    },
    "leanContextBudget": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/leanContextBudget.py"
      ]
    },
    "leanTestReporter": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/leanTestReporter.py"
      ]
    },
    "security": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/securityMcp.py"
      ]
    },
    "secureOsv": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/secureOsv.py"
      ]
    }
  }
}
