{
  "mcpServers": {
    "cursorTools": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/cursorToolsMcp.py"
      ]
    },
    "workspaceTesting": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/workspaceTestingMcp.py"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/gitMcp.py"
      ]
    },
    "web": {
      "command": "uvx",
      "args": [
        "--with",
        "httpx",
        "--with",
        "markdownify",
        "--with",
        "beautifulsoup4",
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/webMcp.py"
      ]
    },
    "devDocs": {
      "command": "uvx",
      "args": [
        "--with",
        "httpx",
        "--with",
        "beautifulsoup4",
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/devDocsMcp.py"
      ]
    },
    "time": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/timeMcp.py"
      ]
    },
    "memory": {
      "command": "uvx",
      "env": {
        "WORKSPACE_ROOT": "${workspaceFolder}"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/memoryMcp.py"
      ]
    },
    "security": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/securityMcp.py"
      ]
    },
    "filesystem": {
      "command": "uvx",
      "env": {
        "FS_ALLOWED_ROOT": "${workspaceFolder}"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.cursor/mcp/scripts/fsMcp.py"
      ]
    }
  }
}
