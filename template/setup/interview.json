{
  "schemaVersion": "0.5.0",
  "questions": [
    {
      "id": "setup.depth",
      "prompt": "How much would you like to customise this install?",
      "type": "choice",
      "batch": "setup",
      "options": ["simple", "advanced", "full"],
      "default": "simple"
    },
    {
      "id": "profile.selected",
      "prompt": "Behavior profile for this workspace",
      "type": "choice",
      "batch": "simple",
      "options": ["balanced", "lean"],
      "default": "balanced"
    },
    {
      "id": "packs.selected",
      "prompt": "Optional capability packs",
      "type": "multi-choice",
      "batch": "simple",
      "options": ["lean", "secure", "tdd"],
      "default": []
    },
    {
      "id": "mcp.enabled",
      "prompt": "Install optional MCP extensions (devDocs, memory) — not git/web/filesystem/time",
      "type": "boolean",
      "batch": "simple",
      "default": false
    },
    {
      "id": "response.style",
      "prompt": "What response style do you prefer?",
      "type": "choice",
      "batch": "advanced",
      "options": ["concise", "balanced", "verbose"],
      "default": "balanced"
    },
    {
      "id": "autonomy.level",
      "prompt": "How should the assistant handle ambiguity?",
      "type": "choice",
      "batch": "advanced",
      "options": ["ask-first", "act-then-tell", "best-judgement"],
      "default": "ask-first"
    },
    {
      "id": "agent.persona",
      "prompt": "What interaction style should the assistant use?",
      "type": "choice",
      "batch": "advanced",
      "options": ["professional", "mentor", "pair-programmer", "direct"],
      "default": "professional"
    },
    {
      "id": "testing.philosophy",
      "prompt": "What is your testing philosophy?",
      "type": "choice",
      "batch": "full",
      "options": ["always", "suggest", "skip"],
      "default": "always"
    },
    {
      "id": "lean.reasoning.mode",
      "prompt": "Lean pack reasoning verbosity",
      "type": "choice",
      "batch": "simple",
      "options": ["compressed", "silent"],
      "default": "compressed",
      "requiredWhen": {
        "any": [
          { "key": "profile.selected", "equals": "lean" },
          { "key": "packs.selected", "contains": "lean" }
        ]
      }
    }
  ]
}
